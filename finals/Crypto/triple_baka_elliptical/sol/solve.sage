from Crypto.Util.number import getPrime, inverse
from Crypto.Cipher import AES
from Crypto.Util.Padding import pad, unpad
import hashlib
import os


def decrypt(secret, iv, ciphertext):
    sha1 = hashlib.sha1()
    sha1.update(str(secret).encode('ascii'))
    key = sha1.digest()[:16]
    iv = bytes.fromhex(iv)
    cipher = AES.new(key, AES.MODE_CBC, iv)
    decrypted = cipher.decrypt(bytes.fromhex(ciphertext))
    return decrypted

p = 105886573969025913437316829028340576120749917395393545078900775119795796908917
a = 14913447334678636586744091818632544201825021590110099928928917985190272508572
b = 8988483279631832375618715923302785696462621573188305903979148179894798461774
E = EllipticCurve(GF(p), [a,b])
order = 105886573969025913437316829028340576120707376139801067826169405348016754727097

keysum = 63874619086447341730367417965972395216020850065565022485266336636320476718232

M = E(6754198569269405729240028180224797800324337061938455146317549498273001171776, 14438415026253474302388871137396872029151710651720417510410255552599591864867)
T = E(38804141322495949657162444334712938485507363985015550208181257315086152705871, 88317839674183721886580559956094913550633062593183479078118183341442746173890)
N = E(94558095358237031191109319005524793823054961363989649101454374630148698477767, 93818094848517782119895287096046216247802428527896052905834556727221491287581)

cubesum = E(51989036097792288634409565536088918594998714459870112246443186990518801365695, 17846491030495489831380351302636594806783712330933178598777705435165624225071)

MT = E(74571959391028173378912572891542889741796813228680444061162998776090545458900, 51204526720617835168393835712569390345648582637466800814891880871891414844844)
TN = E(46398338024180898654182123949705279144314906156783037350813985619035834143019, 91962127546365100216948634023393087628388698876007692905617193879909477348981)
NM = E(25421955306758237913118234568557822457270842421269647365355283579404965123911, 66238787993747955399629535801663329204294147125944778254439102375733204050604)

data = {'iv': '7cd322610fa30fa9c2b19759db145a78', 'encrypted_flag': 'a0fabf39e014db42c32fc1f77b1af0980ddbab109612f3dfc37d846f48ba2163b16f863419b8ecc74778c4ace0e4f88a5e062245e962bb0be329d0f528c8fd3d'}

# We use the identity a^3 + b^3 + c^3 - 3abc = (a + b + c)(a^2 + b^2 + c^2 - ab - bc - ca).
# The heuristic for the special triplet is that a^2+b^2+c^2 = 0 (mod order)
# Since we know everything else, solution becomes trivial.

MTN = (cubesum + keysum * (MT+TN+NM)) * pow(3, -1, order)
print(decrypt(MTN.xy()[0], data['iv'], data['encrypted_flag']))