# ── ASRCTF Adaptive Prompt Injection Vault v2 ──
# Copy this file to .env and fill in the values before deploying.

# Optional: Override the API keys already present in config/challenge.json
# OPENAI_API_KEYS=gsk_REPLACE_ME_KEY1,gsk_REPLACE_ME_KEY2

# Required: Admin dashboard token (set to a strong random string)
ASRCTF_ADMIN_TOKEN=changeme_to_a_strong_random_token

# Optional: Override the API base URL (default: https://api.groq.com/openai/v1)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Optional: Override the target model (default: llama-3.1-8b-instant)
# ASRCTF_BASE_MODEL=llama-3.1-8b-instant

# Optional: Override the judge model (default: llama-3.1-8b-instant)
# ASRCTF_JUDGE_MODEL=llama-3.1-8b-instant

# Optional: Override the secret flag at runtime
# ASRCTF_SECRET_FLAG=ASRCTF{du4l_1lm_judG3_s3m4n71c_v3c70r_byp455_v2}
