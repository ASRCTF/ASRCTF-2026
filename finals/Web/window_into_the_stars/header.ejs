<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Ares Deep Space Observatory</title>
    <style>
@import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syncopate:wght@400;700&display=swap');

:root {
    --bg-dark: #010205;
    --primary: #00f2fe;
    --primary-glow: rgba(0, 242, 254, 0.5);
    --secondary: #4facfe;
    --danger: #ff0844;
    --text-main: #e0fbfc;
    --text-dim: #8d99ae;
    --panel-bg: rgba(6, 11, 25, 0.85);
    --border-color: rgba(0, 242, 254, 0.3);
}

body {
    background-color: var(--bg-dark);
    /* Pure CSS Starfield Effect */
    background-image: 
        radial-gradient(1px 1px at 25px 5px, white, transparent),
        radial-gradient(1px 1px at 50px 25px, white, transparent),
        radial-gradient(1px 1px at 125px 20px, rgba(255,255,255,0.8), transparent),
        radial-gradient(1.5px 1.5px at 50px 75px, white, transparent),
        radial-gradient(2px 2px at 15px 125px, rgba(255,255,255,0.9), transparent),
        radial-gradient(1px 1px at 110px 80px, white, transparent);
    background-size: 150px 150px;
    color: var(--text-main);
    font-family: 'Share Tech Mono', monospace;
    margin: 0;
    padding: 0;
    min-height: 100vh;
}

/* CRT Scanline Overlay */
body::after {
    content: " ";
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.03), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.03));
    z-index: 2;
    background-size: 100% 4px, 6px 100%;
    pointer-events: none;
}

h1, h2, h3, .brand {
    font-family: 'Syncopate', sans-serif;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 2px;
}

a {
    color: var(--primary);
    text-decoration: none;
    transition: all 0.3s;
}
a:hover {
    color: #fff;
    text-shadow: 0 0 10px var(--primary-glow);
}

.navbar {
    background: linear-gradient(180deg, rgba(2,5,15,1) 0%, rgba(2,5,15,0.7) 100%);
    padding: 20px 50px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border-color);
    box-shadow: 0 0 20px rgba(0, 242, 254, 0.2);
    position: relative;
    z-index: 10;
}

.brand {
    font-size: 1.5em;
    font-weight: 700;
    text-shadow: 0 0 15px var(--primary-glow);
    position: relative;
}

.nav-links a {
    margin-left: 30px;
    font-size: 0.9em;
    font-weight: bold;
}

.container {
    padding: 50px 20px;
    max-width: 900px;
    margin: 0 auto;
    position: relative;
    z-index: 10;
}

.hero {
    text-align: center;
    margin-top: 60px;
}
.hero h1 {
    font-size: 2.8em;
    margin-bottom: 15px;
    text-shadow: 0 0 20px var(--primary-glow);
}
.hero p {
    font-size: 1.2em;
    color: var(--text-dim);
    margin-bottom: 50px;
}

.btn {
    display: inline-block;
    padding: 15px 30px;
    background: transparent;
    color: var(--primary);
    border: 1px solid var(--primary);
    cursor: pointer;
    font-family: 'Syncopate', sans-serif;
    font-size: 0.8em;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: all 0.3s;
    /* Angled sci-fi corners */
    clip-path: polygon(10px 0, 100% 0, 100% calc(100% - 10px), calc(100% - 10px) 100%, 0 100%, 0 10px);
    box-shadow: inset 0 0 10px rgba(0, 242, 254, 0.1);
}
.btn:hover {
    background: var(--primary);
    color: var(--bg-dark);
    box-shadow: 0 0 20px var(--primary-glow);
}

.form-container, .signals-container, .search-container, .add-container {
    background: var(--panel-bg);
    padding: 40px;
    border: 1px solid var(--border-color);
    box-shadow: 0 0 30px rgba(0,0,0,0.8), inset 0 0 20px rgba(0, 242, 254, 0.05);
    backdrop-filter: blur(5px);
    margin-bottom: 40px;
    /* Sci-fi panel shape */
    clip-path: polygon(0 0, calc(100% - 20px) 0, 100% 20px, 100% 100%, 20px 100%, 0 calc(100% - 20px));
}

label {
    display: block;
    margin-bottom: 8px;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
}

input, textarea {
    width: 100%;
    box-sizing: border-box;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid var(--border-color);
    color: #fff;
    padding: 15px;
    margin-bottom: 25px;
    font-family: 'Share Tech Mono', monospace;
    font-size: 1.1em;
    transition: border 0.3s, box-shadow 0.3s;
}

input:focus, textarea:focus {
    outline: none;
    border-color: var(--primary);
    box-shadow: 0 0 15px var(--primary-glow);
}

.error {
    background: rgba(255, 8, 68, 0.15);
    color: var(--danger);
    border-left: 4px solid var(--danger);
    padding: 15px;
    margin-bottom: 25px;
}

.message {
    background: rgba(0, 242, 254, 0.15);
    color: var(--primary);
    border-left: 4px solid var(--primary);
    padding: 15px;
    margin-bottom: 25px;
}

.preview-box {
    border: 1px solid var(--border-color);
    background: rgba(0, 0, 0, 0.5);
    padding: 20px;
    margin-bottom: 20px;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);
    border-left: 4px solid var(--primary);
}

.preview-box h4 {
    margin-top: 0;
    color: var(--text-dim);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 10px;
}

ul { list-style: none; padding: 0; }
li {
    padding: 15px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    font-size: 1.1em;
}
li::before {
    content: "> ";
    color: var(--primary);
}

</style>
</head>
<body>
    <nav class="navbar">
        <div class="brand">ARES D.S.O.</div>
        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/report">Report Signal</a>
            <% if (typeof user !== 'undefined' && user) { %>
                <a href="/dashboard">Dashboard</a>
                <a href="/logout">Logout [<%= user %>]</a>
            <% } else { %>
                <a href="/login">Login</a>
            <% } %>
        </div>
    </nav>
    <div class="container">
