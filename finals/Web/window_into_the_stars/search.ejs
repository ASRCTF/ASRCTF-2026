<%- include('header') %>
<h2>Search Results</h2>
<p>Query: <strong><%= query %></strong></p>

<% if (results.length === 0) { %>
    <p class="error">No signals matched the query.</p>
<% } else { %>
    <p>Found <%= results.length %> matches.</p>
    <div class="spectrogram-list">
        <% results.forEach(sig => { %>
            <div class="preview-box">
                <h4>Signal ID: <%= sig.id %></h4>
                <iframe src="/spectrogram/<%= sig.id %>" width="100%" height="150" frameborder="0"></iframe>
            </div>
        <% }) %>
    </div>
<% } %>
<br>
<a href="/dashboard" class="btn">Return to Dashboard</a>
<%- include('footer') %>
