<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Spectrogram View</title>
    <style>
        body { background: #000; color: #0f0; font-family: monospace; overflow: hidden; margin: 0; padding: 10px; }
        .spectrogram {
            display: flex;
            align-items: flex-end;
            height: 80px;
            gap: 2px;
            margin-bottom: 10px;
        }
        .bar {
            width: 10px;
            background: #0f0;
            animation: pulse 1s infinite alternate;
        }
        @keyframes pulse {
            0% { height: 10px; }
            100% { height: 80px; }
        }
        .bar:nth-child(2n) { animation-delay: 0.2s; }
        .bar:nth-child(3n) { animation-delay: 0.4s; }
        .bar:nth-child(5n) { animation-delay: 0.1s; }
        .data { font-size: 14px; }
    </style>
</head>
<body>
    <div class="spectrogram">
        <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
        <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
        <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
    </div>
    <div class="data">
        <%= signal.title %><br>
        <%= signal.content %>
    </div>
</body>
</html>
